# Your Hermes Agent deployment's OpenAI-compatible API server.
# Must end in /v1 (the route appends /chat/completions).
HERMES_URL=https://your-hermes.up.railway.app/v1

# The API_SERVER_KEY you set on the Hermes side.
HERMES_API_KEY=replace-me

# Optional: override the model name sent to Hermes. Defaults to "hermes-agent".
# HERMES_MODEL=hermes-agent
